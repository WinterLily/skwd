#!/bin/bash

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"
SKWD_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/skwd"
CONFIG_FILE="$SKWD_CONFIG/data/config.json"

echo "╔══════════════════════════════════════════════════════════════════════╗"
echo "║        SKWD — Initial Setup with fancy ASCII art! Tihi!              ║"
echo "╚══════════════════════════════════════════════════════════════════════╝"
echo ""

# Check required commands
CORE_CMDS=(jq python3 quickshell)
missing=()
for cmd in "${CORE_CMDS[@]}"; do
  command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
done
if [[ ${#missing[@]} -gt 0 ]]; then
  echo "  WARNING: Missing required commands: ${missing[*]}"
  echo "  Install them before running skwd."
  echo ""
fi

# Detect primary monitor using niri or hyprland commands
monitor=""
if command -v niri >/dev/null 2>&1 && pgrep -x niri >/dev/null 2>&1; then
  monitor=$(niri msg -j outputs 2>/dev/null | jq -r 'keys[0]' 2>/dev/null)
elif [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
  monitor=$(hyprctl -j monitors 2>/dev/null | jq -r '.[0].name' 2>/dev/null)
fi
[ -z "$monitor" ] && monitor="DP-1"
echo "Monitor: $monitor"

# Detect WiFi interface
wifi_if=""
for iface in /sys/class/net/wl*; do
  [ -d "$iface" ] && wifi_if=$(basename "$iface") && break
done
[ -z "$wifi_if" ] && wifi_if="wlan0"
echo "Wi-Fi: $wifi_if"

# Detect GPU vendor
gpu="unknown"
if command -v nvidia-smi >/dev/null 2>&1; then
  gpu="nvidia"
elif [ -d /sys/class/drm/card0/device ] && grep -qi amd /sys/class/drm/card0/device/uevent 2>/dev/null; then
  gpu="amd"
elif [ -d /sys/class/drm/card0/device ] && grep -qi intel /sys/class/drm/card0/device/uevent 2>/dev/null; then
  gpu="intel"
fi
echo "GPU: $gpu"

# Locate Steam and Wallpaper Engine paths
steam_dir=""
for d in "$HOME/.local/share/Steam" "$HOME/.steam/steam"; do
  [ -d "$d" ] && steam_dir="$d" && break
done

we_assets=""
[ -n "$steam_dir" ] && [ -d "$steam_dir/steamapps/common/wallpaper_engine/assets" ] && \
  we_assets="$steam_dir/steamapps/common/wallpaper_engine/assets"

we_dir=""
if [ -n "$steam_dir" ] && [ -f "$steam_dir/steamapps/libraryfolders.vfs" ]; then
  for lib in $(jq -r '.[] | .path // empty' "$steam_dir/steamapps/libraryfolders.vfs" 2>/dev/null); do
    candidate="$lib/steamapps/workshop/content/431960"
    [ -d "$candidate" ] && we_dir="$candidate" && break
  done
fi
[ -z "$we_dir" ] && [ -d "$steam_dir/steamapps/workshop/content/431960" ] && \
  we_dir="$steam_dir/steamapps/workshop/content/431960"

echo ""

# Create required directories
SKWD_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/skwd"
mkdir -p "$SKWD_CACHE"
mkdir -p "$SKWD_CACHE/wallpaper"
mkdir -p "$SKWD_CACHE/app-launcher"
mkdir -p "$HOME/wallpaper" 2>/dev/null || true
mkdir -p "${XDG_RUNTIME_DIR:-/tmp}/skwd" 2>/dev/null || true

# Seed cache files that QML components expect (avoids warnings on first run)
[ -f "$SKWD_CACHE/bar-state" ] || echo "true" > "$SKWD_CACHE/bar-state"
[ -f "$SKWD_CACHE/colors.json" ] || echo '{}' > "$SKWD_CACHE/colors.json"
[ -f "$SKWD_CACHE/wallpaper/tags.json" ] || echo '{}' > "$SKWD_CACHE/wallpaper/tags.json"
[ -f "$SKWD_CACHE/wallpaper/colors.json" ] || echo '{}' > "$SKWD_CACHE/wallpaper/colors.json"
[ -f "$SKWD_CACHE/wallpaper/matugen-colors.json" ] || echo '{}' > "$SKWD_CACHE/wallpaper/matugen-colors.json"
[ -f "$SKWD_CACHE/app-launcher/freq.json" ] || echo '{}' > "$SKWD_CACHE/app-launcher/freq.json"
[ -f "$SKWD_CACHE/wallpaper/steam-dl-status.json" ] || echo '{}' > "$SKWD_CACHE/wallpaper/steam-dl-status.json"

# Create config.json from example if missing
mkdir -p "$SKWD_CONFIG/data"
if [ ! -f "$CONFIG_FILE" ]; then
  cp "$PROJECT_DIR/data/config.json.example" "$CONFIG_FILE"
  # Patch in auto-detected values
  tmp=$(mktemp)
  jq \
    --arg monitor "$monitor" \
    --arg wifi_if "$wifi_if" \
    --arg we_dir "${we_dir:-}" \
    --arg we_assets "${we_assets:-}" \
    --arg steam_dir "${steam_dir:-}" \
    '.monitor = $monitor
     | .components.bar.wifi.interface = $wifi_if
     | .paths.steamWorkshop = $we_dir
     | .paths.steamWeAssets = $we_assets
     | .paths.steam = $steam_dir' \
    "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  echo "Created data/config.json from example"
fi

# Create secrets.json from example if missing
if [ ! -f "$SKWD_CONFIG/data/secrets.json" ]; then
  cp "$PROJECT_DIR/data/secrets.json.example" "$SKWD_CONFIG/data/secrets.json"
  echo "Created data/secrets.json from example"
fi

# Create apps.json from example if missing
if [ ! -f "$SKWD_CONFIG/data/apps.json" ]; then
  cp "$PROJECT_DIR/data/apps.json.example" "$SKWD_CONFIG/data/apps.json"
  echo "Created data/apps.json from example"
fi

echo ""
# Set up Python venv and install dependencies
VENV_DIR="$SKWD_CONFIG/.venv"
if [ ! -d "$VENV_DIR" ]; then
  echo "Creating Python virtual environment..."
  python3 -m venv "$VENV_DIR"
  "$VENV_DIR/bin/pip" install -q -r "$PROJECT_DIR/scripts/requirements.txt"
  echo "Installed Python dependencies."
else
  echo "Python venv already exists at $VENV_DIR"
fi

# Generate matugen config from template + config.json integrations
MATUGEN_TEMPLATE="$PROJECT_DIR/ext/matugen/config.toml.in"
MATUGEN_CONFIG="$SKWD_CACHE/matugen-config.toml"
if [ -f "$MATUGEN_TEMPLATE" ]; then
  # Read integration output paths from config.json (empty string = disabled)
  int_kitty=$(jq -r '.integrations.kitty // ""' "$CONFIG_FILE")
  int_kde=$(jq -r '.integrations.kde // ""' "$CONFIG_FILE")
  int_vscode=$(jq -r '.integrations.vscode // ""' "$CONFIG_FILE")
  int_vesktop=$(jq -r '.integrations.vesktop // ""' "$CONFIG_FILE")
  int_zen=$(jq -r '.integrations.zen // ""' "$CONFIG_FILE")
  int_spicetify=$(jq -r '.integrations.spicetify // ""' "$CONFIG_FILE")
  int_spicetify_css=$(jq -r '.integrations.spicetifyCss // ""' "$CONFIG_FILE")
  int_yazi=$(jq -r '.integrations.yazi // ""' "$CONFIG_FILE")
  int_qt6ct=$(jq -r '.integrations.qt6ct // ""' "$CONFIG_FILE")

  sed \
    -e "s|@SKWD_INSTALL@|$PROJECT_DIR|g" \
    -e "s|@OUTPUT_KITTY@|$int_kitty|g" \
    -e "s|@OUTPUT_KDE@|$int_kde|g" \
    -e "s|@OUTPUT_VSCODE@|$int_vscode|g" \
    -e "s|@OUTPUT_VESKTOP@|$int_vesktop|g" \
    -e "s|@OUTPUT_ZEN@|$int_zen|g" \
    -e "s|@OUTPUT_SPICETIFY@|$int_spicetify|g" \
    -e "s|@OUTPUT_SPICETIFYCSS@|$int_spicetify_css|g" \
    -e "s|@OUTPUT_YAZI@|$int_yazi|g" \
    -e "s|@OUTPUT_QT6CT@|$int_qt6ct|g" \
    "$MATUGEN_TEMPLATE" > "$MATUGEN_CONFIG.tmp"

  # Remove template blocks where output_path is empty
  python3 -c "
import re, sys
text = open(sys.argv[1]).read()
# Remove [templates.X] blocks where output_path is empty
text = re.sub(r'\n\[templates\.\w+\]\ninput_path = \"[^\"]*\"\noutput_path = \"\"\n', '\n', text)
open(sys.argv[1], 'w').write(text)
" "$MATUGEN_CONFIG.tmp"

  mv "$MATUGEN_CONFIG.tmp" "$MATUGEN_CONFIG"
  echo "Generated matugen config at $MATUGEN_CONFIG"
fi

# Wire up app integrations (idempotent — safe to re-run)
echo ""
echo "Wiring app integrations..."

# Kitty: ensure includes point to skwd-generated theme files
KITTY_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/kitty/kitty.conf"
if [ -f "$KITTY_CONF" ]; then
  grep -q 'include skwd-theme.conf' "$KITTY_CONF" || \
    sed -i '1i include skwd-theme.conf' "$KITTY_CONF"
  grep -q 'include skwd-tabs.conf' "$KITTY_CONF" || \
    sed -i '/include skwd-theme.conf/a include skwd-tabs.conf' "$KITTY_CONF"
  echo "  Kitty: includes wired"
fi

# Oh My Posh: symlink theme into standard location
OMP_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/oh-my-posh"
OMP_THEME="$PROJECT_DIR/ext/omp/skwd.omp.json"
if command -v oh-my-posh >/dev/null 2>&1 || [ -x "$HOME/.local/bin/oh-my-posh" ]; then
  mkdir -p "$OMP_DIR"
  ln -sfn "$OMP_THEME" "$OMP_DIR/skwd.omp.json"
  echo "  OMP: theme linked at $OMP_DIR/skwd.omp.json"
fi

# Wallpaper Engine path check
if command -v linux-wallpaperengine >/dev/null 2>&1; then
  if [[ -z "$we_assets" ]]; then
    echo ""
    echo "  WARNING: linux-wallpaperengine is installed but Wallpaper Engine's"
    echo "  Steam assets directory was not found. Make sure you have Wallpaper"
    echo "  Engine installed via Steam, then re-run setup or update the paths"
    echo "  in data/config.json manually."
  fi
fi

echo ""
echo "Initial setup complete, now you need to customise the settings in config.json and add some wallpapers to ~/wallpaper/"
echo "Next steps:"
echo "  1. Edit $SKWD_CONFIG/data/config.json to set your city, paths, etc."
echo "  2. Place wallpapers in ~/wallpaper/"
echo "  3. Run: skwd  (or quickshell -p $PROJECT_DIR)"
echo ""
echo "Optional:"
echo "  - Edit data/secrets.json for Home Assistant integration"
echo "  - Install matugen for dynamic color schemes"
echo ""
echo "IPC: qs ipc -p $PROJECT_DIR call <target> <function>"
echo "Supported targets: lock, powermenu, launcher, bar, smarthome, switcher, notifications, config"
