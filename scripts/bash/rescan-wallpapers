#!/bin/bash
# Rescan wallpapers to detect videos in Wallpaper Engine items
# Usage: rescan-wallpapers [all|we]
#   all - Force full rescan of all wallpapers
#   we  - Rescan only Wallpaper Engine items (default)

. "$(dirname "$0")/lib.sh"

FIFO="${SKWD_RUNTIME:-/tmp/skwd-$USER}/cmd"

if [ ! -p "$FIFO" ]; then
    echo "Error: IPC pipe not found at $FIFO"
    echo "Is the shell running?"
    exit 1
fi

MODE="${1:-we}"

case "$MODE" in
    all|full|force)
        echo "Forcing full wallpaper rescan..."
        echo "wallpaper-rescan" > "$FIFO"
        ;;
    we|workshop|steam)
        echo "Rescanning Wallpaper Engine items for videos..."
        echo "wallpaper-rescan-we" > "$FIFO"
        ;;
    *)
        echo "Usage: rescan-wallpapers [all|we]"
        echo "  all - Force full rescan of all wallpapers"
        echo "  we  - Rescan only Wallpaper Engine items (default)"
        exit 1
        ;;
esac

echo "Rescan triggered. Check the wallpaper selector to see progress."
